DATABASE_URL=postgresql://user:password@localhost:5432/popc
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

LOG_LEVEL=info
LOG_PRETTY=true
PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

MAX_ASSET_SIZE_BYTES=104857600
MAX_CLOCK_SKEW_SECONDS=300
DEFAULT_POLICY=default

# Abuse controls
IP_RATE_LIMIT_PER_MINUTE=240

# Development-only flags (must remain false in production)
DISABLE_API_AUTH=false
ALLOW_INSECURE_ATTESTATION_DEV=false
ALLOW_CLIENT_SECURITY_OVERRIDE=false
ALLOW_SOFTWARE_KEYS=false
ALLOW_VERIFY_URL_FETCH=false
ALLOW_WEB_SOFTWARE_ENROLLMENT=true
